# Whop OAuth — get these from whop.com/dashboard/developer
VITE_WHOP_CLIENT_ID=app_xxxxxxxxxxxxxxxxxx
VITE_WHOP_REDIRECT_URI=https://yourdomain.vercel.app/api/auth/callback
WHOP_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHOP_REDIRECT_URI=https://yourdomain.vercel.app/api/auth/callback

# Supabase — get these from supabase.com → project → settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter — free vision model for photo validation
VITE_OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxx
